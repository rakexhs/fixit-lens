# Root reference for all environment variables used across FixIt Lens.
# Backend reads these from backend/.env (copy backend/.env.example there).
# Mobile reads EXPO_PUBLIC_API_BASE_URL from mobile/.env (copy mobile/.env.example there).

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./fixit_lens.db
APP_ENV=development
DEMO_MODE=false
PROVIDER_PRIORITY=gemini,openai,mock
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-1.5-flash
GEMINI_TEXT_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini
USE_LOCAL_HEAVY_MODELS=false
USE_LOCAL_EMBEDDINGS=false
MAX_IMAGE_MB=8
IMAGE_STORAGE_DIR=./data/uploads
SAFETY_STRICT_MODE=true
REQUIRE_CITATIONS=true
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
